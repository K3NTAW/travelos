generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  traveler
  coordinator
  admin
}

enum CreditLedgerType {
  grant
  usage
  top_up
}

model Organization {
  id              String            @id
  name            String
  createdAt       DateTime          @default(now()) @map("created_at")
  workspaces      Workspace[]
  users           User[]
  trips           Trip[]
  auditEvents     AuditEvent[]
  affiliateClicks AffiliateClick[]
  creditLedger    CreditLedgerEntry[]

  @@map("organizations")
}

model Workspace {
  id            String       @id
  orgId         String       @map("org_id")
  name          String
  seatCount     Int          @default(1) @map("seat_count")
  creditBalance Int          @default(0) @map("credit_balance")
  createdAt     DateTime     @default(now()) @map("created_at")
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("workspaces")
}

model User {
  id          String       @id
  orgId       String       @map("org_id")
  email       String       @unique
  role        UserRole
  createdAt   DateTime     @default(now()) @map("created_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  trips       Trip[]
  auditEvents AuditEvent[] @relation("AuditActor")

  @@map("users")
}

model Trip {
  id          String        @id
  orgId       String        @map("org_id")
  travelerId  String        @map("traveler_id")
  destination String
  startDate   DateTime      @map("start_date")
  endDate     DateTime      @map("end_date")
  riskScore   Int           @default(0) @map("risk_score")
  createdAt   DateTime      @default(now()) @map("created_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  traveler     User         @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  affiliateClicks AffiliateClick[]

  @@map("trips")
}

model AuditEvent {
  id          BigInt        @id @default(autoincrement())
  orgId       String        @map("org_id")
  actorId     String        @map("actor_id")
  action      String
  resource    String
  createdAt   DateTime      @default(now()) @map("created_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor       User          @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@map("audit_events")
}

model AffiliateClick {
  id          BigInt        @id @default(autoincrement())
  orgId       String        @map("org_id")
  tripId      String        @map("trip_id")
  provider    String
  targetUrl   String        @map("target_url")
  createdAt   DateTime      @default(now()) @map("created_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  trip        Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("affiliate_clicks")
}

model CreditLedgerEntry {
  id          String         @id
  orgId       String         @map("org_id")
  type        CreditLedgerType
  credits     Int
  context     String
  createdAt   DateTime       @default(now()) @map("created_at")
  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("credit_ledger_entries")
}
